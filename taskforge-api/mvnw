#!/bin/sh
# Maven Wrapper script
# Downloads and runs Apache Maven if not found locally

set -e

# Resolve the project base directory
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

# Default Maven version
DEFAULT_DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"

# Read distributionUrl from properties if available
if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
    DIST_URL=$(grep "^distributionUrl=" "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2- | tr -d '\r')
fi
DIST_URL="${DIST_URL:-$DEFAULT_DIST_URL}"

# Maven home directory
MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
MAVEN_HOME="$MAVEN_USER_HOME/wrapper/dists/$(basename "$DIST_URL" .zip)"

# Download and extract Maven if needed
if [ ! -d "$MAVEN_HOME" ]; then
    echo "Downloading Maven from $DIST_URL"
    mkdir -p "$MAVEN_HOME"
    TMP_FILE=$(mktemp)
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL "$DIST_URL" -o "$TMP_FILE"
    elif command -v wget > /dev/null 2>&1; then
        wget -q "$DIST_URL" -O "$TMP_FILE"
    else
        echo "Error: curl or wget required" >&2
        exit 1
    fi
    unzip -q "$TMP_FILE" -d "$MAVEN_HOME"
    rm -f "$TMP_FILE"
fi

# Find mvn executable
MVN=$(find "$MAVEN_HOME" -name "mvn" -not -name "*.cmd" -type f | head -1)
if [ -z "$MVN" ]; then
    echo "Error: mvn executable not found in $MAVEN_HOME" >&2
    exit 1
fi

chmod +x "$MVN"
exec "$MVN" -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" "$@"
